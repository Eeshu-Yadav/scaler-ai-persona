# --- LiveKit Cloud (project settings -> Keys) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- STT + fallback TTS (console.deepgram.com -> API Keys, $200 free credit) ---
DEEPGRAM_API_KEY=

# --- Primary TTS (elevenlabs.io -> Profile -> API Keys) ---
ELEVENLABS_API_KEY=
# Voice to clone/use; default is "Adam". Replace with your cloned voice id if you make one.
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Gemini (LLM + RAG query embeddings) ---
GEMINI_API_KEY=
# Optional numbered fallback keys — each has its own free-tier daily quota:
GEMINI_API_KEY_1=
# VOICE_MODEL auto-selects per provider (gemini-2.5-flash / gpt-4o-mini). Override:
# VOICE_MODEL=

# --- Cal.com booking (same values as backend/.env) ---
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# Optional: corpus override (defaults to ../data/corpus.json)
# CORPUS_PATH=
