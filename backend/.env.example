# --- Gemini (sole LLM/embeddings provider) — free key: aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional numbered fallback keys — each has its own free-tier daily quota:
GEMINI_API_KEY_1=


# --- Cal.com (real calendar booking) ---
# Settings -> Developer -> API Keys
CALCOM_API_KEY=
# Numeric ID of your "Interview" event type (visible in the event type URL)
CALCOM_EVENT_TYPE_ID=

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*
# Comma-separated frontend origins, e.g. https://eeshu-chat.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# --- Models ---
# Models auto-select per provider (gemini-2.5-flash / gpt-4o). Override here if needed:
# CHAT_MODEL=
# EMBEDDING_MODEL=

# Optional: override corpus location (defaults to ../data/corpus.json)
# CORPUS_PATH=
